static void bl2_nor_erase(void)
{
	/* Erase sector command via IP */
	xspi_ip_write(BL2_LOG_ADDR,
	              NULL,
	              BL2_LOG_SIZE,
	              XSPI_OP_SECTOR_ERASE);
}



static void bl2_log_to_nor(uint32_t err,
                           uint32_t image,
                           uint32_t line)
{
	bl2_log_t log = {
		.magic = BL2_LOG_MAGIC,
		.err = err,
		.image_id = image,
		.line = line,
	};

	/* Erase first */
	bl2_nor_erase();

	/* Write using IP mode */
	xspi_ip_write(BL2_LOG_ADDR,
	              &log,
	              sizeof(log),
	              XSPI_OP_PAGE_PROGRAM);
}




