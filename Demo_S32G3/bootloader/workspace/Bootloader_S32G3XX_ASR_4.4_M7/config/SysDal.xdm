                    </d:var>
                    <d:var name="EnableScheduling" type="BOOLEAN" value="false"/>
                    <d:var name="SchedulingTimeNew" type="INTEGER" value=""/>
                    <d:ref name="GptTimerNew" type="REFERENCE" value=""/>
                    <d:lst name="InterruptList" type="MAP">
                      <d:ctr name="LINFLEXD0_UART_IRQHandler" 
