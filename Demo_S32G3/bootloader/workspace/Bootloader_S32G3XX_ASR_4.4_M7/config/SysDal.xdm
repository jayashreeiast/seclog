                      <a:a name="IMPORTER_INFO" value="@DEF"/>
                    </d:var>
                    <d:lst name="SysDalDigitalWakeup" type="MAP"/>
                    <d:lst name="SysDalAnalogWakeup" type="MAP"/>
                  </d:ctr>
                </d:lst>
                <d:lst name="SystemPowerUpConfig" type="MAP">
                  <d:ctr name="SystemPowerUpConfig_0" type="IDENTIFIABLE">
                    <d:lst name="InitList" type="MAP">
                      <d:ctr name="Port_Init" type="IDENTIFIABLE">
                        <d:var name="Parameters" type="STRING" 
                               value="&amp;Port_Config"/>
                        <d:var name="CalloutHeader" type="FUNCTION-NAME" 
                               value="Port.h"/>
                        <d:var name="CalloutApplicability" type="ENUMERATION" 
                               value="InitBlockZero"/>
                      </d:ctr>
                      <d:ctr name="Mcl_Init" type="IDENTIFIABLE">
                        <d:var name="Parameters" type="STRING" 
