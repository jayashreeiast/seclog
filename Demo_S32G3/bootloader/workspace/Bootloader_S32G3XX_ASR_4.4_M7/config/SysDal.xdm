                      </d:ctr>
                    </d:lst>
                  </d:ctr>
                </d:lst>
                <d:lst name="SchedulingConfig" type="MAP">
                  <d:ctr name="SchedulingConfig_0" type="IDENTIFIABLE">
                    <d:var name="SelectAutosarOS" type="BOOLEAN" value="false">
