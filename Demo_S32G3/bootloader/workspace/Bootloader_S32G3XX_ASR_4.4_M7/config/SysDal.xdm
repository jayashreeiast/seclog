                        <d:var name="InterruptNumber" type="INTEGER" value="82"/>
                        <d:var name="InterruptPriority" type="INTEGER" value="7"/>
                      </d:ctr>
                    </d:lst>
                    <d:lst name="TaskList" type="MAP">
                      <d:ctr name="TaskList_0" type="IDENTIFIABLE">
                        <d:var name="AppTaskId" type="ENUMERATION" 
                               value="INTAPP_PREHOOK_TASK"/>
                        <d:var name="TaskActivationTime" type="INTEGER" >
                          <a:a name="IMPORTER_INFO" value="@DEF"/>
                        </d:var>
                        <d:var name="OsEventName" type="FUNCTION-NAME" >
                          <a:a name="IMPORTER_INFO" value="@DEF"/>
                        </d:var>
                        <d:lst name="TaskFunctionList" type="MAP"/>
                      </d:ctr>
                    </d:lst>
                  </d:ctr>
                </d:lst>
                <d:lst name="WatchDogConfig" type="MAP">
                  <d:ctr name="WatchDogConfig_0" type="IDENTIFIABLE">
                    <d:var name="EnableWdg" type="BOOLEAN" value="false">
                      <a:a name="IMPORTER_INFO" value="@DEF"/>
                    </d:var>
                    <d:var name="EnableWdgResetTest" type="BOOLEAN" 
