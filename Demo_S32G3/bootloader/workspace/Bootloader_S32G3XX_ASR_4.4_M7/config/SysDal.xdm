                      <a:a name="IMPORTER_INFO" value="@DEF"/>
                    </d:var>
                    <d:ref name="WdgChannelRef" type="REFERENCE" >
                      <a:a name="IMPORTER_INFO" value="@DEF"/>
                    </d:ref>
                    <d:var name="WdgRunMode" type="ENUMERATION" value="WDG_SLOW">
                      <a:a name="IMPORTER_INFO" value="@DEF"/>
                    </d:var>
                    <d:var name="WdgTriggerTime" type="INTEGER" value="10000">
                      <a:a name="IMPORTER_INFO" value="@DEF"/>
                    </d:var>
                  </d:ctr>
                </d:lst>
              </d:ctr>
              <d:lst name="RtmConfiguration" type="MAP">
                <d:ctr name="RtmConfiguration_0" type="IDENTIFIABLE">
                  <d:ctr name="RtmGeneral" type="IDENTIFIABLE">
                    <d:var name="RtmTimerType" type="ENUMERATION" 
