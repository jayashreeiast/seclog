                        <d:var name="CalloutHeader" type="FUNCTION-NAME" 
                               value="Mcl.h"/>
                        <d:var name="CalloutApplicability" type="ENUMERATION" 
                               value="InitBlockZero"/>
                      </d:ctr>
                      <d:ctr name="SysDal_Rtm_Init" type="IDENTIFIABLE">
                        <d:var name="Parameters" type="STRING" >
                          <a:a name="IMPORTER_INFO" value="@DEF"/>
                        </d:var>
                        <d:var name="CalloutHeader" type="FUNCTION-NAME" 
                               value="SysDal_Rtm.h"/>
                        <d:var name="CalloutApplicability" type="ENUMERATION" 
                               value="InitBlockZero"/>
                      </d:ctr>
                      <d:ctr name="SysDal_Rtm_StartMeasurement" 
                             type="IDENTIFIABLE">
                        <d:var name="Parameters" type="STRING" value="2"/>
                        <d:var name="CalloutHeader" type="FUNCTION-NAME" 
                               value="SysDal_Rtm.h"/>
                        <d:var name="CalloutApplicability" type="ENUMERATION" 
                               value="InitBlockZero"/>
                      </d:ctr>
                      <d:ctr name="Uart_Init" type="IDENTIFIABLE">
                        <d:var name="Parameters" type="STRING" 
                               value="&amp;Uart_xConfig"/>
                        <d:var name="CalloutHeader" type="FUNCTION-NAME" 
                               value="CDD_Uart.h"/>
                        <d:var name="CalloutApplicability" type="ENUMERATION" 
                               value="InitBlockZero"/>
                      </d:ctr>
                      <d:ctr name="SysDal_Wait" type="IDENTIFIABLE">
                        <d:var name="Parameters" type="STRING" value="20000"/>
                        <d:var name="CalloutHeader" type="FUNCTION-NAME" 
                               value="SysDal.h"/>
                        <d:var name="CalloutApplicability" type="ENUMERATION" 
                               value="InitBlockZero"/>
                      </d:ctr>
                      <d:ctr name="ComDal_Init" type="IDENTIFIABLE">
                        <d:var name="Parameters" type="STRING" 
                               value="&amp;ComDal_Config[0]"/>
                        <d:var name="CalloutHeader" type="FUNCTION-NAME" 
                               value="ComDal.h"/>
                        <d:var name="CalloutApplicability" type="ENUMERATION" 
