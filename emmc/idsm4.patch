+/*
+ * ═══════════════════════════════════════════════════════════════════════════
+ * STEP 2A — IMPORT AES-256 KEY
+ *
+ * VERIFIED FIELD NAMES for HSE_FW_S32G3XX_0_2_64_0:
+ *
+ * hseImportKeySrv_t top-level fields (from hse_srv_key_import_export.h):
+ *   targetKeyHandle       hseKeyHandle_t
+ *   pKeyInfo              HOST_ADDR  → phys addr of hseKeyInfo_t
+ *   cipherKeyHandle       hseKeyHandle_t  ← direct field, NOT cipher.cipherKeyHandle
+ *                         Set to HSE_INVALID_KEY_HANDLE for plain (unencrypted) import
+ *
+ * keyContainer union — member names in FW 0_2_64_0:
+ *   FOR SYMMETRIC (AES/HMAC):
+ *     keyContainer.sym.keyLen    uint16_t  — byte length of key
+ *     keyContainer.sym.pKey      HOST_ADDR — phys addr of raw key bytes
+ *   FOR RSA PAIR/PUB:
+ *     keyContainer.rsa.modulusLength  uint16_t
+ *     keyContainer.rsa.pModulus       HOST_ADDR
+ *     keyContainer.rsa.pubExpLength   uint16_t
+ *     keyContainer.rsa.pPubExp        HOST_ADDR
+ *     keyContainer.rsa.pPrivExp       HOST_ADDR  (0 for public-only)
+ *
+ * IF THESE STILL FAIL: run on your build machine:
+ *   grep -A 60 "typedef struct.*hseImportKey\|} hseImportKeySrv_t" \
+ *     $(find /yocto-BSP43 -name "hse_srv_key_import_export.h")
+ * and paste the output — I will fix the field names immediately.
+ * ═══════════════════════════════════════════════════════════════════════════
+ */
+static int idsm_import_aes256_key(void)
+{
+    hseSrvDescriptor_t  desc = {0};
+    hseImportKeySrv_t  *imp  = &desc.hseSrv.importKeyReq;
+    hseKeyInfo_t        ki   = {0};
+    void  *ki_buf  = NULL;
+    void  *key_buf = NULL;
+    int    ret     = -ENOMEM;
+
+    ki_buf  = hse_mem_alloc(sizeof(hseKeyInfo_t));
+    key_buf = hse_mem_alloc(32U);
+
+    if ((ki_buf == NULL) || (key_buf == NULL)) {
+        ERROR("IDSM: AES key import alloc failed\n");
+        goto done;
+    }
+
+    memset(&ki, 0, sizeof(ki));
+
+    ki.keyType   = HSE_KEY_TYPE_AES;
+    ki.keyBitLen = 256U;
+    ki.keyFlags  =
+        (uint16_t)(HSE_KF_USAGE_ENCRYPT | HSE_KF_USAGE_DECRYPT);
+
+    hse_memcpy(ki_buf,   &ki,                    sizeof(hseKeyInfo_t));
+    hse_memcpy(key_buf,   IDSM_AES256_KEY_BYTES,  32U);
+
+    memset(&desc, 0, sizeof(desc));
+
+    desc.srvId = HSE_SRV_ID_IMPORT_KEY;
+
+    imp->targetKeyHandle = IDSM_NVM_AES256_KEY_HANDLE;
+    imp->pKeyInfo        = hse_virt_to_phys(ki_buf);
+
+    /*
+     * FW 0_2_64_0 container format
+     * AES key = single buffer
+     */
+    imp->pKey[0] =
+        hse_virt_to_phys(key_buf);
+
+    imp->keyLen[0] = 32U;
+
+    ret = hse_srv_req_sync(HSE_CHANNEL_CRYPTO, &desc);
+
+    if (ret != 0) {
+        ERROR("IDSM: AES import failed ret=%d\n", ret);
+    } else {
+        NOTICE("IDSM: AES-256 imported OK\n");
+    }
+
+done:
+
+    if (key_buf != NULL)
+        hse_mem_free(key_buf);
+
+    if (ki_buf != NULL)
+        hse_mem_free(ki_buf);
+
+    return ret;
+}
+
+/*
+ * ═══════════════════════════════════════════════════════════════════════════
+ * STEP 2B — IMPORT RSA-2048 PRIVATE KEY PAIR
+ *   keyType  = HSE_KEY_TYPE_RSA_PAIR  (n + e + d)
+ *   keyFlags = HSE_KF_USAGE_SIGN
+ *   pPrivExp ≠ 0  → tells HSE this is a key pair, not public-only
+ * ═══════════════════════════════════════════════════════════════════════════
+ */
+static int idsm_import_rsa_priv_key(void)
+{
+    hseSrvDescriptor_t desc = {0};
+    hseImportKeySrv_t *imp  = &desc.hseSrv.importKeyReq;
+    hseKeyInfo_t ki         = {0};
+
+    void *ki_buf = NULL;
+    void *n_buf  = NULL;
+    void *e_buf  = NULL;
+    void *d_buf  = NULL;
+
+    int ret = -ENOMEM;
+
+    ki_buf = hse_mem_alloc(sizeof(hseKeyInfo_t));
+    n_buf  = hse_mem_alloc(256U);
+    e_buf  = hse_mem_alloc(sizeof(IDSM_RSA_E));
+    d_buf  = hse_mem_alloc(256U);
+
+    if ((ki_buf == NULL) ||
+        (n_buf  == NULL) ||
+        (e_buf  == NULL) ||
+        (d_buf  == NULL)) {
+
+        ERROR("IDSM: RSA priv import alloc failed\n");
+        goto done;
+    }
+
+    memset(&ki, 0, sizeof(ki));
+
+    ki.keyType   = HSE_KEY_TYPE_RSA_PAIR;
+    ki.keyBitLen = 2048U;
+    ki.keyFlags  = (uint16_t)HSE_KF_USAGE_SIGN;
+
+    hse_memcpy(ki_buf, &ki,          sizeof(hseKeyInfo_t));
+    hse_memcpy(n_buf,   IDSM_RSA_N,  256U);
+    hse_memcpy(e_buf,   IDSM_RSA_E,  sizeof(IDSM_RSA_E));
+    hse_memcpy(d_buf,   IDSM_RSA_D,  256U);
+
+    memset(&desc, 0, sizeof(desc));
+
+    desc.srvId = HSE_SRV_ID_IMPORT_KEY;
+
+    imp->targetKeyHandle = IDSM_NVM_RSA_PAIR_KEY_HANDLE;
+    imp->pKeyInfo        = hse_virt_to_phys(ki_buf);
+
+    /*
+     * FW 0_2_64_0 RSA container layout:
+     *
+     * pKey[0] = modulus
+     * pKey[1] = public exponent
+     * pKey[2] = private exponent
+     */
+
+    imp->pKey[0] =
+        hse_virt_to_phys(n_buf);
+
+    imp->keyLen[0] = 256U;
+
+    imp->pKey[1] =
+        hse_virt_to_phys(e_buf);
+
+    imp->keyLen[1] =
+        (uint16_t)sizeof(IDSM_RSA_E);
+
+    imp->pKey[2] =
+        hse_virt_to_phys(d_buf);
+
+    imp->keyLen[2] = 256U;
+
+    ret = hse_srv_req_sync(HSE_CHANNEL_CRYPTO, &desc);
+
+    if (ret != 0) {
+        ERROR("IDSM: RSA private import failed ret=%d\n", ret);
+    } else {
+        NOTICE("IDSM: RSA private key imported OK\n");
+    }
+
+done:
+
+    if (d_buf != NULL)
+        hse_mem_free(d_buf);
+
+    if (e_buf != NULL)
+        hse_mem_free(e_buf);
+
+    if (n_buf != NULL)
+        hse_mem_free(n_buf);
+
+    if (ki_buf != NULL)
+        hse_mem_free(ki_buf);
+
+    return ret;
+}
+
+/*
+ * ═══════════════════════════════════════════════════════════════════════════
+ * STEP 2C — IMPORT RSA-2048 PUBLIC KEY
+ *   keyType  = HSE_KEY_TYPE_RSA_PUB  (n + e only, NO d)
+ *   keyFlags = HSE_KF_USAGE_VERIFY
+ *   pPrivExp = 0  → mandatory for public-only import
+ * ═══════════════════════════════════════════════════════════════════════════
+ */
+static int idsm_import_rsa_pub_key(void)
+{
+    hseSrvDescriptor_t desc = {0};
+    hseImportKeySrv_t *imp  = &desc.hseSrv.importKeyReq;
+    hseKeyInfo_t ki         = {0};
+
+    void *ki_buf = NULL;
+    void *n_buf  = NULL;
+    void *e_buf  = NULL;
+
+    int ret = -ENOMEM;
+
+    ki_buf = hse_mem_alloc(sizeof(hseKeyInfo_t));
+    n_buf  = hse_mem_alloc(256U);
+    e_buf  = hse_mem_alloc(sizeof(IDSM_RSA_E));
+
+    if ((ki_buf == NULL) ||
+        (n_buf  == NULL) ||
+        (e_buf  == NULL)) {
+
+        ERROR("IDSM: RSA pub import alloc failed\n");
+        goto done;
+    }
+
+    memset(&ki, 0, sizeof(ki));
+
+    ki.keyType   = HSE_KEY_TYPE_RSA_PUB;
+    ki.keyBitLen = 2048U;
+    ki.keyFlags  = (uint16_t)HSE_KF_USAGE_VERIFY;
+
+    hse_memcpy(ki_buf, &ki, sizeof(hseKeyInfo_t));
+
+    hse_memcpy(n_buf, IDSM_RSA_N, 256U);
+    hse_memcpy(e_buf, IDSM_RSA_E, sizeof(IDSM_RSA_E));
+
+    memset(&desc, 0, sizeof(desc));
+
+    desc.srvId = HSE_SRV_ID_IMPORT_KEY;
+
+    imp->targetKeyHandle = IDSM_NVM_RSA_PUB_KEY_HANDLE;
+    imp->pKeyInfo        = hse_virt_to_phys(ki_buf);
+
+    /*
+     * Public key:
+     * pKey[0] = modulus
+     * pKey[1] = exponent
+     */
+
+    imp->pKey[0] =
+        hse_virt_to_phys(n_buf);
+
+    imp->keyLen[0] = 256U;
+
+    imp->pKey[1] =
+        hse_virt_to_phys(e_buf);
+
+    imp->keyLen[1] =
+        (uint16_t)sizeof(IDSM_RSA_E);
+
+    ret = hse_srv_req_sync(HSE_CHANNEL_CRYPTO, &desc);
+
+    if (ret != 0) {
+        ERROR("IDSM: RSA public import failed ret=%d\n", ret);
+    } else {
+        NOTICE("IDSM: RSA public key imported OK\n");
+    }
+
+done:
+
+    if (e_buf != NULL)
+        hse_mem_free(e_buf);
+
+    if (n_buf != NULL)
+        hse_mem_free(n_buf);
+
+    if (ki_buf != NULL)
+        hse_mem_free(ki_buf);
+
+    return ret;
+}
+
+static void idsm_provision_keys(void)
+{
+    if (s_keys_ready)
+        return;
+
+    NOTICE("IDSM: Provisioning keys into HSE NVM catalog...\n");
+
+    if (idsm_import_aes256_key() != 0) {
+        ERROR("IDSM: AES key provision failed — secure logging disabled\n");
+        return;
+    }
+
+    if (idsm_import_rsa_priv_key() != 0) {
+        ERROR("IDSM: RSA private key provision failed — secure logging disabled\n");
+        return;
+    }
+
+    /* Public key import is non-fatal — used for verify only */
+    if (idsm_import_rsa_pub_key() != 0)
+        WARN("IDSM: RSA public key provision failed — verify unavailable\n");
+
+    s_keys_ready = 1;
+    NOTICE("IDSM: All keys provisioned. Secure logging active.\n");
+}
+
+/*
+ * ═══════════════════════════════════════════════════════════════════════════
+ * STEP 3A — AES-256-GCM ENCRYPT THE TIMESTAMP FRAME
+ *
+ * Uses: IDSM_NVM_AES256_KEY_HANDLE (NVM,7,1)
+ * Union member: desc.hseSrv.aeadReq  (confirmed in hse_interface.h)
+ * Service ID:   HSE_SRV_ID_AEAD = 0x00A50204UL
+ *
+ * Parameters:
+ *   cipherDir     = HSE_CIPHER_DIR_ENCRYPT
+ *   authCipherMode= HSE_AUTH_CIPHER_MODE_GCM
+ *   keyHandle     = IDSM_NVM_AES256_KEY_HANDLE
+ *   ivLength      = 12  (96-bit nonce)
+ *   pIV           → phys addr of 12-byte nonce
+ *   aadLength     = 8   (event_frame size — authenticated, not encrypted)
+ *   pAAD          → phys addr of event_frame
+ *   inputLength   = 8   (timestamp frame size)
+ *   pInput        → phys addr of plaintext timestamp
+ *   pOutput       → phys addr of ciphertext output
+ *   tagLength     = 16  (128-bit GCM auth tag)
+ *   tagLength (uint32_t by value in FW 0_2_64_0 — no pointer needed)
+ *   pTag          → phys addr of 16-byte tag output
+ * ═══════════════════════════════════════════════════════════════════════════
+ */
+/*
+ * ═══════════════════════════════════════════════════════════════════════════
+ * STEP 3A — AES-256-GCM ENCRYPT TIMESTAMP
+ *
+ * VERIFIED FIX for FW 0_2_64_0:
+ *   hseAeadSrv_t has NO 'pTagLength' field.
+ *   It has 'tagLength' as a plain uint32_t (by value, not a pointer).
+ *   Proof: compiler said "did you mean 'tagLength'?"
+ *   Fix: set aead->tagLength = 16U; directly. No tlen_buf needed.
+ * ═══════════════════════════════════════════════════════════════════════════
+ */
+static int idsm_aes_gcm_encrypt(
+        const idsm_timestamp_frame_t  *plain_ts,
+        const idsm_event_frame_t      *aad_ef,
+        const uint8_t                  iv[IDSM_GCM_IV_BYTES],
+        idsm_timestamp_frame_t        *out_enc_ts,
+        uint8_t                        out_tag[IDSM_GCM_TAG_BYTES])
+{
+    hseSrvDescriptor_t  desc     = {0};
+    hseAeadSrv_t       *aead     = &desc.hseSrv.aeadReq;
+
+    void    *iv_buf  = NULL, *aad_buf = NULL;
+    void    *in_buf  = NULL, *out_buf = NULL;
+    void    *tag_buf = NULL;
+    uint32_t data_len = (uint32_t)IDSM_TIMESTAMP_BYTES;
+    uint32_t aad_len  = (uint32_t)IDSM_EVENT_FRAME_BYTES;
+    int      ret      = -ENOMEM;
+
+    /* NOTE: No tlen_buf — tagLength is set by VALUE in FW 0_2_64_0 */
+    iv_buf   = hse_mem_alloc((uint32_t)IDSM_GCM_IV_BYTES);
+    aad_buf  = hse_mem_alloc(aad_len);
+    in_buf   = hse_mem_alloc(data_len);
+    out_buf  = hse_mem_alloc(data_len);
+    tag_buf  = hse_mem_alloc((uint32_t)IDSM_GCM_TAG_BYTES);
+
+    if (!iv_buf || !aad_buf || !in_buf || !out_buf || !tag_buf) {
+        ERROR("IDSM: GCM alloc OOM\n");
+        goto done;
+    }
+
+    hse_memcpy(iv_buf,  iv,       (uint32_t)IDSM_GCM_IV_BYTES);
+    hse_memcpy(aad_buf, aad_ef,   aad_len);
+    hse_memcpy(in_buf,  plain_ts, data_len);
+
+    desc.srvId           = HSE_SRV_ID_AEAD;
+    aead->accessMode     = HSE_ACCESS_MODE_ONE_PASS;
+    aead->authCipherMode = HSE_AUTH_CIPHER_MODE_GCM;
+    aead->cipherDir      = HSE_CIPHER_DIR_ENCRYPT;
+    aead->keyHandle      = IDSM_NVM_AES256_KEY_HANDLE;
+    aead->ivLength       = (uint32_t)IDSM_GCM_IV_BYTES;
+    aead->pIV            = hse_virt_to_phys(iv_buf);
+    aead->aadLength      = aad_len;
+    aead->pAAD           = hse_virt_to_phys(aad_buf);
+    aead->inputLength    = data_len;
+    aead->pInput         = hse_virt_to_phys(in_buf);
+    aead->pOutput        = hse_virt_to_phys(out_buf);
+    aead->tagLength      = (uint32_t)IDSM_GCM_TAG_BYTES; /* by VALUE in FW 0_2_64_0 */
+    aead->pTag           = hse_virt_to_phys(tag_buf);
+    /* NO pTagLength field in this FW version */
+
+    ret = hse_srv_req_sync(HSE_CHANNEL_CRYPTO, &desc);
+    if (ret != 0) {
+        ERROR("IDSM: AES-GCM encrypt failed ret=%d\n", ret);
+        goto done;
+    }
+
+    hse_memcpy(out_enc_ts, out_buf,  data_len);
+    hse_memcpy(out_tag,    tag_buf,  (uint32_t)IDSM_GCM_TAG_BYTES);
+    NOTICE("IDSM: AES-256-GCM encrypt OK\n");
+
+done:
+    if (tag_buf) hse_mem_free(tag_buf);
+    if (out_buf) hse_mem_free(out_buf);
+    if (in_buf)  hse_mem_free(in_buf);
+    if (aad_buf) hse_mem_free(aad_buf);
+    if (iv_buf)  hse_mem_free(iv_buf);
+    return ret;
+}
+
+static int idsm_rsa_pkcs1_sign(
+        const idsm_event_frame_t     *ef,
+        const idsm_timestamp_frame_t *enc_ts,
+        uint8_t                       out_sig[IDSM_RSA_SIG_BYTES])
+{
+    hseSrvDescriptor_t  desc   = {0};
+    hseSignSrv_t       *sign   = &desc.hseSrv.signReq;
+
+    /*
+     * Contiguous sign input:
+     *   [event_frame (8B)] | [enc_timestamp (8B)] = 16 bytes total.
+     * Per AUTOSAR Figure 5.2: "EventFrame + Optional Timestamp".
+     */
+    uint8_t  sign_input[IDSM_EVENT_FRAME_BYTES + IDSM_TIMESTAMP_BYTES];
+    uint32_t sign_len = (uint32_t)sizeof(sign_input);
+    uint32_t sig_len  = (uint32_t)IDSM_RSA_SIG_BYTES;
+
+    memcpy(sign_input,                         ef,     IDSM_EVENT_FRAME_BYTES);
+    memcpy(sign_input + IDSM_EVENT_FRAME_BYTES, enc_ts, IDSM_TIMESTAMP_BYTES);
+
+    void *in_buf   = hse_mem_alloc(sign_len);
+    void *sig_buf  = hse_mem_alloc(sig_len);
+    void *slen_buf = hse_mem_alloc(sizeof(uint32_t)); /* in/out sig length */
+    int   ret      = -ENOMEM;
+
+    if (!in_buf || !sig_buf || !slen_buf) {
+        ERROR("IDSM: RSA sign alloc OOM\n");
+        goto done;
+    }
+
+    hse_memcpy(in_buf,   sign_input, sign_len);
+    hse_memcpy(slen_buf, &sig_len,   sizeof(uint32_t));
+    memset(sig_buf, 0, sig_len);
+    flush_dcache_range((uintptr_t)sig_buf, sig_len);
+
+    desc.srvId                                      = HSE_SRV_ID_SIGN;
+    sign->accessMode                                = HSE_ACCESS_MODE_ONE_PASS;
+    sign->keyHandle                                 = IDSM_NVM_RSA_PAIR_KEY_HANDLE;
+    sign->signScheme.signSch                        = HSE_SIGN_RSASSA_PKCS1_V15;
+    sign->signScheme.sch.rsaPkcs1v15.hashAlgo       = HSE_HASH_ALGO_SHA2_256;
+    sign->bInputIsHashed                            = FALSE;
+    sign->inputLength                               = sign_len;
+    sign->pInput                                    = hse_virt_to_phys(in_buf);
+    sign->pSignatureLength[0]                       = hse_virt_to_phys(slen_buf);
+    sign->pSignature[0]                             = hse_virt_to_phys(sig_buf);
+    sign->pSignatureLength[1]                       = 0U; /* unused */
+    sign->pSignature[1]                             = 0U; /* unused */
+
+    ret = hse_srv_req_sync(HSE_CHANNEL_CRYPTO, &desc);
+    if (ret != 0) {
+        ERROR("IDSM: RSA sign failed ret=%d\n", ret);
+        goto done;
+    }
+
+    hse_memcpy(out_sig, sig_buf, sig_len);
+    NOTICE("IDSM: RSA-2048-PKCS1v15-SHA256 sign OK\n");
+
+done:
+    if (slen_buf) hse_mem_free(slen_buf);
+    if (sig_buf)  hse_mem_free(sig_buf);
+    if (in_buf)   hse_mem_free(in_buf);
+    return ret;
+}
+
+/*
+ * ═══════════════════════════════════════════════════════════════════════════
+ * SECURE WRITE PATH — builds full AUTOSAR-compliant 512-byte record
+ *
+ * Full sequence for one event:
+ *   1. Build event_frame    (AUTOSAR fixed header, 8B)
+ *   2. Build GCM IV         (counter-based 12B nonce)
+ *   3. Build timestamp_frame (8B plaintext)
+ *   4. AES-256-GCM encrypt timestamp_frame
+ *        → enc_timestamp (8B) + gcm_tag (16B)
+ *        AAD = event_frame (8B)
+ *   5. Build sig_frame header (sig_len field = 256)
+ *   6. RSA-2048-PKCS1v15-SHA256 sign (event_frame + enc_timestamp)
+ *        → 256-byte signature into sig_frame.sig_data
+ *   7. Flush cache + write 512-byte record to eMMC
+ * ═══════════════════════════════════════════════════════════════════════════
+ */
+//#ifdef HSE_SECBOOT
+static void idsm_write_secure(uint16_t event_id, uint16_t count,
+                               uint32_t sector)
+{
+    /* Static to avoid BL2 stack pressure; aligned for cache maintenance */
+    static idsm_secure_record_t s_rec __attribute__((aligned(64)));
+    idsm_timestamp_frame_t plain_ts;
+    int ret;
+
+    memset(&s_rec, 0, sizeof(s_rec));
+
+    /* 1. Build event frame (Protocol Header = TS | SIG = 0x06) */
+    build_event_frame(&s_rec.event_frame,
+                      (uint16_t)IDSM_INSTANCE_A_CORE,
+                      (uint8_t) IDSM_MODULE_SECBOOT,
+                      (uint8_t) IDSM_HDR_TS_AND_SIG,
+                      event_id,
+                      count);
+
+    /* 2. Build GCM IV */
+    build_gcm_iv(s_rec.gcm_iv, s_log_index);
+
+    /* 3. Build plaintext timestamp */
+    build_timestamp_frame(&plain_ts);
+
+    /* 4. AES-256-GCM encrypt timestamp, AAD = event_frame */
+    ret = idsm_aes_gcm_encrypt(&plain_ts,
+                                &s_rec.event_frame,
+                                s_rec.gcm_iv,
+                                &s_rec.enc_timestamp,
+                                s_rec.gcm_tag);
+    if (ret != 0) {
+        ERROR("IDSM: GCM failed (0x%04X) — plaintext fallback\n", event_id);
+        /* Graceful fallback: write plain event frame + timestamp */
+        uint8_t blk[IDSM_BLOCK_SIZE] = {0};
+        memcpy(blk, &s_rec.event_frame, IDSM_EVENT_FRAME_BYTES);
+        mmc_write_blocks(sector, (uintptr_t)blk, 512);
+        memset(blk, 0, IDSM_BLOCK_SIZE);
+        memcpy(blk, &plain_ts, IDSM_TIMESTAMP_BYTES);
+        mmc_write_blocks(sector + 1U, (uintptr_t)blk, 512);
+        return;
+    }
+
+    /* 5. Write Signature Length field (big-endian = 256) */
+    s_rec.sig_frame.sig_len_hi = (uint8_t)((IDSM_RSA_SIG_BYTES >> 8) & 0xFFU);
+    s_rec.sig_frame.sig_len_lo = (uint8_t)( IDSM_RSA_SIG_BYTES        & 0xFFU);
+
+    /* 6. RSA-2048 sign (event_frame + enc_timestamp) per AUTOSAR spec */
+    ret = idsm_rsa_pkcs1_sign(&s_rec.event_frame,
+                               &s_rec.enc_timestamp,
+                               s_rec.sig_frame.sig_data);
+    if (ret != 0) {
+        ERROR("IDSM: RSA sign failed (0x%04X) — dropping record\n", event_id);
+        return;
+    }
+
+    /* 7. Flush cache and write 512-byte sector */
+    flush_dcache_range((uintptr_t)&s_rec, sizeof(s_rec));
+
+    ret = mmc_write_blocks(sector, (uintptr_t)&s_rec, 512);
+    if (ret != 512) {
+        ERROR("IDSM: mmc_write_blocks failed ret=%d sector=%u\n",
+              ret, sector);
+        return;
+    }
+
+    NOTICE("IDSM: secured record written sector=%u seq=%u event=0x%04X\n",
+           sector, s_log_index, event_id);
+}
+//#endif /* HSE_SECBOOT */
+
+/*
+ * ═══════════════════════════════════════════════════════════════════════════
+ * PLAINTEXT FALLBACK WRITE (2 sectors, original layout)
+ * Used when HSE is not ready or keys not provisioned.
+ * ═══════════════════════════════════════════════════════════════════════════
+ */
+static void idsm_write_plain(uint16_t event_id, uint16_t count,
+                              uint32_t base_sector)
+{
+    idsm_event_frame_t     ef;
+    idsm_timestamp_frame_t ts;
+    uint8_t                blk[IDSM_BLOCK_SIZE];
+    int                    ret;
+
+    build_event_frame(&ef,
+                      (uint16_t)IDSM_INSTANCE_A_CORE,
+                      (uint8_t) IDSM_MODULE_SECBOOT,
+                      (uint8_t) IDSM_HDR_TS_ONLY,
+                      event_id, count);
+    build_timestamp_frame(&ts);
+
+    memset(blk, 0, IDSM_BLOCK_SIZE);
+    memcpy(blk, &ef, IDSM_EVENT_FRAME_BYTES);
+    ret = mmc_write_blocks(base_sector, (uintptr_t)blk, 512);
+    if (ret != 512) {
+        ERROR("IDSM_PT: event write FAILED sector=%u ret=%d\n",
+              base_sector, ret);
+        return;
+    }
+
+    memset(blk, 0, IDSM_BLOCK_SIZE);
+    memcpy(blk, &ts, IDSM_TIMESTAMP_BYTES);
+    ret = mmc_write_blocks(base_sector + 1U, (uintptr_t)blk, 512);
+    if (ret != 512) {
+        ERROR("IDSM_PT: ts write FAILED sector=%u ret=%d\n",
+              base_sector + 1U, ret);
+        return;
+    }
+
+    NOTICE("IDSM_PT: plain event=0x%04X written sector=%u\n",
+           event_id, base_sector);
+}
