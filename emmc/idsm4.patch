+/*
+ * ═══════════════════════════════════════════════════════════════════════════
+ * AUTOSAR IdsM WIRE FORMAT STRUCTS
+ * ═══════════════════════════════════════════════════════════════════════════
+ */
+
+/*
+ * Fixed Event Frame (8 bytes) — always present.
+ *   Byte 0:  [7:4]=Version  [3:0]=Header flags
+ *   Byte 1:  Instance Id [9:2]
+ *   Byte 2:  [7:6]=Instance Id[1:0]  [5:0]=Module Id
+ *   Byte 3:  Event Id [15:8]
+ *   Byte 4:  Event Id [7:0]
+ *   Byte 5:  Count [15:8]
+ *   Byte 6:  Count [7:0]
+ *   Byte 7:  Reserve = 0x00
+ */
+typedef struct {
+    uint8_t ver_hdr;        /* [7:4]=version  [3:0]=hdr_flags */
+    uint8_t inst_hi;        /* Instance Id [9:2] */
+    uint8_t inst_lo_mod;    /* [7:6]=Instance Id[1:0]  [5:0]=Module Id */
+    uint8_t event_hi;       /* Event Id [15:8] */
+    uint8_t event_lo;       /* Event Id [7:0] */
+    uint8_t count_hi;       /* Count [15:8] */
+    uint8_t count_lo;       /* Count [7:0] */
+    uint8_t reserve;        /* 0x00 */
+} __attribute__((packed)) idsm_event_frame_t;   /* = 8 bytes */
+
+/*
+ * Timestamp Frame (8 bytes) — present when Header Bit[1]=1.
+ *   Byte[0]:   Bit[7]=type(0=AUTOSAR,1=OEM)  Bit[6]=reserved
+ *   Bytes[1..7]: ms timestamp, big-endian, 7 bytes
+ */
+typedef struct {
+    uint8_t type_flags;     /* Bit[7]=type, Bit[6:0]=reserved */
+    uint8_t ts_ms[7];       /* big-endian ms value */
+} __attribute__((packed)) idsm_timestamp_frame_t;   /* = 8 bytes */
+
+/*
+ * Signature Frame (258 bytes for RSA-2048) — present when Header Bit[2]=1.
+ *   Bytes[0..1]: Signature Length (big-endian) = IDSM_RSA_SIG_BYTES = 256
+ *   Bytes[2..257]: RSA-PKCS1v15-SHA256 signature data
+ *
+ * Per spec: "Signature calculated with EventFrame + Optional Timestamp
+ *            + Optional Context Data"
+ * We sign: event_frame(8B) + enc_timestamp(8B) = 16 bytes total.
+ */
+typedef struct {
+    uint8_t sig_len_hi;                        /* Length[15:8] */
+    uint8_t sig_len_lo;                        /* Length[7:0]  */
+    uint8_t sig_data[IDSM_RSA_SIG_BYTES];      /* 256-byte RSA signature */
+} __attribute__((packed)) idsm_signature_frame_t;   /* = 258 bytes */
+
+/*
+ * On-disk secured record (exactly 512 bytes = 1 eMMC sector).
+ *
+ *   Offset   Size   Field
+ *      0       8    event_frame    (plain — used as AES-GCM AAD)
+ *      8      12    gcm_iv         (nonce, not part of AUTOSAR wire format)
+ *     20      16    gcm_tag        (AES-GCM auth tag)
+ *     36       8    enc_timestamp  (AES-256-GCM ciphertext of timestamp frame)
+ *     44     258    sig_frame      (AUTOSAR Signature Frame: 2B len + 256B RSA)
+ *    302     210    pad            (zero fill to 512)
+ */
+#define IDSM_RECORD_PAD \
+    (IDSM_BLOCK_SIZE \
+     - IDSM_EVENT_FRAME_BYTES \
+     - IDSM_GCM_IV_BYTES \
+     - IDSM_GCM_TAG_BYTES \
+     - IDSM_TIMESTAMP_BYTES \
+     - (IDSM_SIG_LEN_FIELD_BYTES + IDSM_RSA_SIG_BYTES))
+/* = 512 - 8 - 12 - 16 - 8 - 258 = 210 */
+
+typedef struct {
+    idsm_event_frame_t      event_frame;        /*   8  offset   0 */
+    uint8_t                 gcm_iv[IDSM_GCM_IV_BYTES];   /* 12  offset   8 */
+    uint8_t                 gcm_tag[IDSM_GCM_TAG_BYTES];  /* 16  offset  20 */
+    idsm_timestamp_frame_t  enc_timestamp;      /*   8  offset  36 */
+    idsm_signature_frame_t  sig_frame;          /* 258  offset  44 */
+    uint8_t                 pad[IDSM_RECORD_PAD]; /* 210 offset 302 */
+} __attribute__((packed)) idsm_secure_record_t;
